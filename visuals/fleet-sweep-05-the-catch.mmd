%%{init: {'theme':'base','themeVariables':{'fontFamily':'Segoe UI, Helvetica, Arial, sans-serif','fontSize':'14px','lineColor':'#5B6B7B','primaryColor':'#DCE9FB','primaryTextColor':'#1B3A66','primaryBorderColor':'#3B6FB5','clusterBkg':'#F7F9FB','clusterBorder':'#AFC0CE'}}}%%
flowchart TD
  title["THE CATCH — why this only works for LOOKERS, not BOOKERS<br/>(the most important finding)"]

  write(["A worker BOOKS a flight<br/>(it CHANGES the world,<br/>not just reads it)"])

  rule["Kernel safety rule:<br/>once the world changes, old answers<br/>MIGHT be wrong, so the whole<br/>whiteboard gets WIPED clean."]

  wipe[("WHITEBOARD WIPED<br/>everyone's saved answers gone.<br/>Next reader pays full price again.")]

  cost["In a big team, ONE worker's booking<br/>wipes the board for EVERYONE.<br/>The lonely worker who never shares<br/>never pays this penalty."]

  cross["We measured the tipping point:<br/>if even 1 action in 100 is a booking,<br/>the wiping happens so often that<br/>sharing becomes a NET LOSS."]

  verdict["BOTTOM LINE (read this):<br/>* read-only fleets (research, lookups, monitoring):<br/>  sharing is a big, clean win that grows with team size.<br/>* fleets that write a lot: sharing back-fires<br/>  because the safety-wipe is too broad."]

  fix["The lead this hands us:<br/>wipe ONLY the one answer that changed,<br/>not the whole board (a finer eraser).<br/>That would push the tipping point way out."]

  write --> rule
  rule --> wipe
  wipe --> cost
  cost --> cross
  cross --> verdict
  verdict --> fix

  class write untrusted
  class rule gate
  class wipe deny
  class cost world
  class cross deny
  class verdict kernel
  class fix pass

  classDef untrusted fill:#FFE9D6,stroke:#E8833A,stroke-width:2px,color:#7A3E12;
  classDef kernel fill:#DCE9FB,stroke:#3B6FB5,stroke-width:2px,color:#1B3A66;
  classDef gate fill:#FFF3CC,stroke:#C9A227,stroke-width:2px,color:#6B5410;
  classDef pass fill:#DBF3E1,stroke:#3FA45F,stroke-width:2px,color:#1C5230;
  classDef deny fill:#FBDDDD,stroke:#C9453F,stroke-width:2px,color:#6E1F1B;
  classDef world fill:#FCEEDB,stroke:#B5792B,stroke-width:2px,color:#5E3D12;

flowchart LR
  s0(("start"))
  run["RUNNABLE / decoding<br/>KV in HBM (L1)"]
  fast["BLOCKED_FAST — fast call (&lt; ~1ms)<br/>stay in HBM (L1): don't page a spinlock wait"]
  slow["BLOCKED_SLOW — slow call (net / sandbox / human)<br/>page KV to DRAM (L2)"]
  sleep["SLEEPING — cron steward, idle long<br/>page to SSD (L3) or recompute (L4)<br/>keep token log + shared-prefix ptr"]
  note["one mechanism, two payoffs:<br/>the same static call table drives BOTH<br/>pre-flight verification AND demand paging"]
  s0 --> run
  run -->|fire fast call| fast
  run -->|fire slow call| slow
  run -->|idle timeout| sleep
  fast -->|tool returns| run
  slow -->|tool returns: page in| run
  sleep -->|resume: page in / recompute| run
  note -.-> run

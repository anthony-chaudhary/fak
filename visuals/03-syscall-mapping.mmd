flowchart LR
  reframe["Keystone reframe: blow the thin 'tool call' up 100x<br/>into the agent OS syscall layer -- the one boundary where<br/>an untrusted process (the model) asks the trusted kernel (DOS)<br/>to touch the world, exactly like int 0x80 for a Unix process"]

  subgraph AK["Agent Kernel"]
    direction TB
    a1(["tool call"])
    a2["versioned typed Tool Table"]
    a3{"DOS Reference Monitor"}
    a4["Tool vDSO<br/>(cheap calls, no trap)"]
    a5{"Pre-flight ladder<br/>(cheapest-check-first)"}
    a6[("Context as protected memory")]
  end

  subgraph OS["Classic OS"]
    direction TB
    o1["syscall (int 0x80)"]
    o2["syscall table / ABI"]
    o3["seccomp-bpf + LSM hook + eBPF"]
    o4["vDSO<br/>(gettimeofday, no kernel trap)"]
    o5["fail-fast / cheapest-check-first"]
    o6[("MMU / memory protection")]
  end

  a1 -.->|"=="| o1
  a2 -.->|"=="| o2
  a3 -.->|"=="| o3
  a4 -.->|"=="| o4
  a5 -.->|"=="| o5
  a6 -.->|"=="| o6

  verdict["Verdict comes from something the agent did NOT author --<br/>git, the file tree, the clock, a schema -- never the model's narration"]

  reframe -.-> AK
  OS -.-> verdict


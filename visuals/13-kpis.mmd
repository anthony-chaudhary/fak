flowchart TD
  base["Fused vs tuned-SGLang baseline<br/>(vLLM/SGLang + separate harness + separate orchestrator)"]
  resp["RESPONSIVENESS<br/>sub-agent latency (p50/p99)<br/>tool-call round-trip (p50/p99)<br/>KV page-in stall p99<br/>(tool-completion to first decoded token)"]
  eff["EFFICIENCY<br/>tokens per resolved task<br/>token per watt per user<br/>cheap-tier token share"]
  always["ALWAYS-ON ENABLERS<br/>idle-reclaim ratio<br/>KV residency ratio (KV not pinned in HBM)<br/>HBM bytes per always-on agent (amortized to suffix)<br/>tier-hit dist (HBM/DRAM/SSD/recompute)"]
  trust["TRUST<br/>context-pollution rate (results quarantined)<br/>pre-flight catch rate (rung 0-2 vs rung 3)<br/>speculation hit rate (committed vs squashed)"]
  harness[["Harness candidates on disk:<br/>tau2-bench, Toolathlon,<br/>metrics-service, tokencost, headroom"]]
  killer["measure, don't assert<br/>(fused vs tuned-SGLang baseline)"]

  base --> resp
  base --> eff
  base --> always
  base --> trust
  resp -.-> harness
  eff -.-> harness
  always -.-> harness
  trust -.-> harness
  base --- killer


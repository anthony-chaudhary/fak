flowchart LR
  live(["live session<br/>tool results stream in"])
  mmu["ctxmmu gate pages each result to a<br/>content-addressed store at WRITE time<br/>(quarantine decided here, once)"]
  live --> mmu

  subgraph CORE["the core image (recall.Recorder.Persist)"]
    direction TB
    man[("manifest.json<br/>page table: roles · digests ·<br/>real extractive descriptor · QUARANTINE state")]
    cas[("cas.json<br/>swap device: content-addressed bytes")]
  end
  mmu --> CORE

  boundary{{"PROCESS BOUNDARY<br/>session ends = a core dump"}}
  CORE --> boundary

  load["recall.Load(dir)<br/>rebuilds a Session with its OWN CAS + a FRESH ctxmmu gate<br/>verifies every blob vs its digest → a tampered device FAILS CLOSED"]
  boundary --> load
  load --> sess(["new Session, self-contained,<br/>ready to Resolve / Recall"])

  note["the seal OUTLIVES the process: a page the gate quarantined<br/>before the boundary stays sealed after it — no memory system<br/>that re-pastes transcript bytes has this. recall makes the<br/>decision DURABLE + re-screenable; it does not change the decision."]
  boundary -.- note


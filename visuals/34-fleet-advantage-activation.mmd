flowchart LR
  classDef tier fill:#EAF3FB,stroke:#3B6FB5,stroke-width:1.5px,color:#1B3A66;
  classDef now fill:#E7F5EC,stroke:#3FA45F,stroke-width:1.5px,color:#14532D;

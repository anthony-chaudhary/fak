{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "dos hook posttool --workspace .",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python \"$CLAUDE_PROJECT_DIR/tools/repo_guard.py\" --hook",
            "type": "command"
          }
        ],
        "matcher": "Bash|Write|Edit|MultiEdit|NotebookEdit"
      },
      {
        "hooks": [
          {
            "command": "dos hook pretool --workspace .",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "dos hook stop --workspace .",
            "type": "command"
          }
        ]
      }
    ]
  }
}

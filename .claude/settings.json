{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "dos hook posttool --workspace .",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "B=\"$CLAUDE_PROJECT_DIR/tools/.bin/repoguard\"; for c in \"$B\" \"$B.exe\"; do [ -x \"$c\" ] && exec \"$c\" --hook; done; exec python \"$CLAUDE_PROJECT_DIR/tools/repo_guard.py\" --hook",
            "type": "command"
          }
        ],
        "matcher": "Bash|Write|Edit|MultiEdit|NotebookEdit"
      },
      {
        "hooks": [
          {
            "command": "dos hook pretool --workspace .",
            "type": "command"
          }
        ],
        "matcher": "Bash|Write|Edit|MultiEdit|NotebookEdit|mcp__.*dos.*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "dos hook stop --workspace .",
            "type": "command"
          }
        ]
      }
    ]
  }
}

#version 450
// add_bias.comp — dst[r,:] += bias[:] over rows x width. Mirrors k_add_bias.
layout(local_size_x = 256) in;

layout(std430, binding = 0) buffer Dbuf { float D[]; };
layout(std430, binding = 1) readonly buffer Bbuf { float B[]; };

layout(push_constant) uniform Push { int rows; int width; } pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    uint total = uint(pc.rows) * uint(pc.width);
    if (i >= total) return;
    D[i] += B[i % uint(pc.width)];
}

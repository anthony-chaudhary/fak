#!/bin/sh
# fleet trunk-discipline guard  --  DOS reason: OFF_TRUNK
#
# Nudges every actor to work directly on the configured development branch (the
# single-tree-on-trunk policy) instead of spinning up stray feature branches / worktrees. This is the
# CROSS-AGENT floor: git runs it below the agent layer, so it binds Claude Code,
# Codex, and a human at the same point -- none of them can talk their way around
# a refusal the way they can around a CLAUDE.md / AGENTS.md sentence.
#
# It is the named "floor" under `dos.toml [reasons.OFF_TRUNK]`: the structured
# reason is the shared vocabulary, this hook is what actually fires.
#
# Mode  (env FLEET_TRUNK_GUARD):  block (default) | warn | off
#   block  refuse creation of an off-trunk branch              (exit 1, aborts txn)
#   warn   allow the ref, print an advisory citing OFF_TRUNK   (exit 0)
#   off    do nothing
# Escape hatch:  FLEET_ALLOW_BRANCH=1 <git cmd>   always allows (e.g. release tooling).
# Allowlisted branch name: [branch_roles].development_branch from dos.toml.
# Pilot cohort (#1703): FLEET_BRANCH_PILOT=1 additionally allowlists
# [branch_roles].pilot_development_branch, so a named shadow-cutover pilot
# worker can create the pilot branch while everyone else stays refused.
# Release tooling uses FLEET_ALLOW_BRANCH=1 when it must create or repair another role branch.
#
# git calls this hook once per phase ("prepared", "committed", "aborted") with the
# transaction (one "<old> <new> <ref>" line per updated ref) on stdin. A branch
# CREATION is a refs/heads/* line whose <old> is all-zeros.

phase="$1"
mode="${FLEET_TRUNK_GUARD:-block}"
[ "$mode" = "off" ] && exit 0
[ "${FLEET_ALLOW_BRANCH:-0}" = "1" ] && exit 0

# A reference-transaction hook runs while git is holding ref/index state. Do not
# start another git process here unless this phase can actually act; nested git
# commands on Git-for-Windows have wedged commits in this hook. In block mode only
# the prepared phase can refuse. In warn mode only the committed phase can print.
case "$mode:$phase" in
	block:prepared|warn:committed) ;;
	*) exit 0 ;;
esac

zero="0000000000000000000000000000000000000000"
created=""
while read -r old new ref; do
	case "$ref" in
		refs/heads/*) : ;;
		*) continue ;;
	esac
	[ "$old" = "$zero" ] || continue          # creations only (skip normal commits)
	name="${ref#refs/heads/}"
	created="$created $name"
done

[ -z "$created" ] && exit 0

# Git runs non-bare hooks from the worktree root. Prefer that cwd over calling
# `git rev-parse` from inside the transaction hook.
repo_root=$(pwd -P 2>/dev/null || pwd)
dos_file="$repo_root/dos.toml"

trimmed_branch_role=""
trim_branch_role() {
	trimmed_branch_role=$1
	while :; do
		case "$trimmed_branch_role" in
			" "*) trimmed_branch_role=${trimmed_branch_role#?} ;;
			"	"*) trimmed_branch_role=${trimmed_branch_role#?} ;;
			*) break ;;
		esac
	done
	while :; do
		case "$trimmed_branch_role" in
			*" ") trimmed_branch_role=${trimmed_branch_role%?} ;;
			*"	") trimmed_branch_role=${trimmed_branch_role%?} ;;
			*) break ;;
		esac
	done
}

branch_role_value() {
	key="$1"
	file="$2"
	[ -r "$file" ] || return 1
	in_roles=0
	while IFS= read -r raw || [ -n "$raw" ]; do
		line=${raw%%#*}
		trim_branch_role "$line"
		line=$trimmed_branch_role
		[ -n "$line" ] || continue
		case "$line" in
			\[*\])
				if [ "$line" = "[branch_roles]" ]; then
					in_roles=1
				else
					in_roles=0
				fi
				continue
				;;
		esac
		[ "$in_roles" = "1" ] || continue
		case "$line" in
			*=*) : ;;
			*) continue ;;
		esac
		k=${line%%=*}
		trim_branch_role "$k"
		k=$trimmed_branch_role
		[ "$k" = "$key" ] || continue
		v=${line#*=}
		trim_branch_role "$v"
		v=$trimmed_branch_role
		case "$v" in
			\"*\") v=${v#\"}; v=${v%\"} ;;
			\'*\') v=${v#\'}; v=${v%\'} ;;
		esac
		printf '%s\n' "$v"
		return 0
	done < "$file"
	return 1
}

development_branch=$(branch_role_value development_branch "$dos_file")
[ -n "$development_branch" ] || development_branch=main

pilot_branch=""
if [ "${FLEET_BRANCH_PILOT:-0}" = "1" ]; then
	pilot_branch=$(branch_role_value pilot_development_branch "$dos_file")
fi

violations=""
for name in $created; do
	[ "$name" = "$development_branch" ] && continue
	[ -n "$pilot_branch" ] && [ "$name" = "$pilot_branch" ] && continue
	violations="$violations $name"
done

[ -z "$violations" ] && exit 0

if [ "$mode" = "block" ]; then
	# abort before the ref is written
	if [ "$phase" = "prepared" ]; then
		echo "OFF_TRUNK (blocked): refusing off-trunk branch creation:$violations" >&2
		echo "  policy: work directly on configured development branch '$development_branch' -- single tree on the trunk (CLAUDE.md / AGENTS.md)." >&2
		echo "  override once: FLEET_ALLOW_BRANCH=1 <git cmd>   |   reason: dos.toml [reasons.OFF_TRUNK]" >&2
		exit 1
	fi
else
	# warn once, after the ref exists
	if [ "$phase" = "committed" ]; then
		echo "OFF_TRUNK (advisory): created off-trunk branch:$violations" >&2
		echo "  prefer committing directly to configured development branch '$development_branch' (single tree on the trunk policy)." >&2
		echo "  see CLAUDE.md / AGENTS.md; hard-enforce with FLEET_TRUNK_GUARD=block." >&2
	fi
fi
exit 0

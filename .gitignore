#   /_tmp_*    : one-off gate/preview scratch (json/md)
#   /*_msg_*.txt: `fak commit` message drops (commit_msg_*, docs_msg_*)
#   /err.txt   : a bare stderr redirect drop
/scratch_*
/slop.json
/slop_*.json
.aeo_*
.aeo-*
/_tmp_*
/*_msg_*.txt
/err.txt

